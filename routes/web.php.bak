Route::middleware(['auth', 'verified'])->prefix('lottery')->name('lottery.')->group(function () {
    Route::get('/', [App\Http\Controllers\LotteryController::class, 'index'])->name('index');
    Route::post('/spin', [App\Http\Controllers\LotteryController::class, 'spin'])->name('spin');
    Route::post('/free-spin', [App\Http\Controllers\LotteryController::class, 'freeSpin'])->name('free-spin');
    Route::get('/history', [App\Http\Controllers\LotteryController::class, 'history'])->name('history');
    Route::get('/leaderboard/{period?}', [App\Http\Controllers\LotteryController::class, 'leaderboard'])->name('leaderboard');
});

